# Copy to .env and fill in values.
# Prisma reads .env from the api/ directory (or set DATABASE_URL when running CLI).

# Required
DATABASE_URL="postgresql://user:password@localhost:5432/factoryflow?sslmode=disable"
JWT_SECRET="your-secret-key-change-in-production"

# Optional — server
PORT=8080
NODE_ENV=development
# CORS allowed origin (default: http://localhost:5173 for Vite dev)
# CORS_ORIGIN=http://localhost:5173

# Optional — seed (bun run seed); defaults used if unset
SEED_SUPERVISOR_EMAIL=supervisor@factory.local
SEED_SUPERVISOR_PASSWORD=Pass@123
SEED_SUPERVISOR_NAME=Default Supervisor
